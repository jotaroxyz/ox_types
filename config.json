{
  "$schema": "https://raw.githubusercontent.com/LuaLS/LLS-Addons/main/schemas/addon_config.schema.json",
  "name": "Overextended",
  "words": ["exports%.ox", "Ox%.", "MySQL%."],
  "settings": {
    "runtime": {
      "version": "",
      "nonstandardSymbol": [
        "/**/",
        "`",
        "+=",
        "-=",
        "*=",
        "/=",
        "<<=",
        ">>=",
        "&=",
        "|=",
        "^="
      ],
      "special": {
        "lib.load": "require"
      },
      "pathStrict": true
    }
  }
}
